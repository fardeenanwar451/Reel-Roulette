# Copy this file to .env and fill in your own values.
# Get both connection strings from your Neon project dashboard:
# https://console.neon.tech -> your project -> Connection Details

# Pooled connection — used by the app at runtime (Prisma Client).
# Neon's pooled string includes "-pooler" in the hostname.
DATABASE_URL=
# Direct (unpooled) connection — used only for migrations (prisma db push / migrate).
# Same as above but WITHOUT "-pooler" in the hostname.
DATABASE_URL_UNPOOLED=
# Free TMDB API key (v3 auth) — get one at https://www.themoviedb.org/settings/api
# Only needed when running data/hydrate.js, not by the app itself.
TMDB_API_KEY=
